                },
                "message": {
                    "type": "string",
                    "example": "show human-readable message"
                }
            }
        },
        "statistics_transport_http.GetStatisticsResponse": {
            "type": "object",
            "properties": {
                "tasks_average_completion_time": {
                    "type": "string",
